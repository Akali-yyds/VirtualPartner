<Window x:Class="VirtualPartnerLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VirtualPartner Launcher"
        Width="780"
        Height="560"
        MinWidth="720"
        MinHeight="500"
        Background="#14161C"
        Foreground="#F2F5FA"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinWidth" Value="92" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F2F5FA" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="VirtualPartner"
                       FontSize="30"
                       FontWeight="SemiBold"
                       Foreground="#FFFFFF" />
            <TextBlock Text="Preparing local services"
                       Margin="0,4,0,0"
                       FontSize="14"
                       Foreground="#AAB2C0" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,28,0,0"
                Padding="18"
                Background="#1E222B"
                BorderBrush="#303746"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText"
                               Text="Waiting to start"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF" />
                    <TextBlock x:Name="PercentText"
                               Grid.Column="1"
                               Text="0%"
                               FontSize="14"
                               Foreground="#AAB2C0" />
                </Grid>
                <ProgressBar x:Name="StartupProgress"
                             Margin="0,14,0,0"
                             Height="12"
                             Minimum="0"
                             Maximum="100"
                             Value="0" />
                <TextBlock x:Name="ErrorText"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           Foreground="#FF8686"
                           Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="DetailedLogsCheckBox"
                      Content="Show detailed logs"
                      Checked="DetailedLogsCheckBox_Changed"
                      Unchecked="DetailedLogsCheckBox_Changed" />
            <TextBlock Grid.Column="1"
                       Text="Saved for next launch"
                       Foreground="#7F8897"
                       FontSize="12"
                       VerticalAlignment="Center" />
        </Grid>

        <Border x:Name="LogsPanel"
                Grid.Row="3"
                Background="#0F1117"
                BorderBrush="#303746"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Startup log"
                           Padding="12,10"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#AAB2C0" />
                <TextBox x:Name="LogTextBox"
                         Grid.Row="1"
                         Margin="12,0,12,12"
                         Background="#0F1117"
                         Foreground="#D6DBE5"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="4"
                    Margin="0,18,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="StartButton"
                    Content="Restart"
                    Click="StartButton_Click"
                    IsEnabled="False" />
            <Button Content="Open logs"
                    Click="OpenLogsButton_Click" />
            <Button Content="Exit"
                    Click="ExitButton_Click" />
        </StackPanel>
    </Grid>
</Window>
